# Lưu ý: mọi biến đều cần tiền tố ORCHESTRATOR_ (env_prefix trong settings.py) —
# thiếu tiền tố sẽ bị Settings âm thầm bỏ qua, dùng default cứng trong code.
ORCHESTRATOR_GRPC_HOST=0.0.0.0
ORCHESTRATOR_GRPC_PORT=50052
ORCHESTRATOR_REDIS_URL=redis://localhost:6379/1
ORCHESTRATOR_REDIS_JOB_TTL_SEC=86400
ORCHESTRATOR_IMAGE_AI_GRPC_TARGET=localhost:50051
ORCHESTRATOR_IMAGE_AI_WIDTH=512
ORCHESTRATOR_IMAGE_AI_HEIGHT=512
ORCHESTRATOR_IMAGE_AI_STEPS=20
ORCHESTRATOR_IMAGE_POLL_INTERVAL_SEC=2
ORCHESTRATOR_IMAGE_POLL_MAX_ATTEMPTS=360

# Story AI (REST/FastAPI) — cảnh báo port 50052 trùng ORCHESTRATOR_GRPC_PORT mặc định,
# đổi 1 trong 2 nếu chạy cùng máy.
ORCHESTRATOR_STORY_AI_API_URL=http://localhost:50052
ORCHESTRATOR_STORY_AI_TIMEOUT_SEC=90
