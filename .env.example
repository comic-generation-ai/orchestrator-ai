# ==============================================================================
# ORCHESTRATOR APPLICATION CONFIGURATION
# ==============================================================================

# Môi trường chạy ứng dụng (development / production)
ORCHESTRATOR_ENV=

# Cấu hình Server gRPC & HTTP
ORCHESTRATOR_GRPC_HOST=
ORCHESTRATOR_GRPC_PORT=

# Cấu hình kết nối Redis
ORCHESTRATOR_REDIS_URL=
ORCHESTRATOR_REDIS_DB=
ORCHESTRATOR_REDIS_JOB_TTL_SEC=

# Cấu hình kết nối và xử lý Image AI gRPC
ORCHESTRATOR_IMAGE_AI_GRPC_TARGET=
ORCHESTRATOR_IMAGE_AI_WIDTH=
ORCHESTRATOR_IMAGE_AI_HEIGHT=
# image-ai (Dreamshaper 8, non-turbo) tự override lên 20 nếu nhận <10, nhưng đặt
# đúng luôn cho khỏi phụ thuộc override ngầm + khỏi log warning mỗi lần gọi.
ORCHESTRATOR_IMAGE_AI_STEPS=

# Cấu hình Polling (kiểm tra trạng thái) của Image Job
ORCHESTRATOR_IMAGE_POLL_INTERVAL_SEC=
ORCHESTRATOR_IMAGE_POLL_MAX_ATTEMPTS=

# Cấu hình kết nối Story AI (REST/FastAPI — không phải gRPC)
# Cảnh báo: story-ai mặc định chạy port 50052 (Config.PORT trong story-ai/src/config.py)
# — TRÙNG với ORCHESTRATOR_GRPC_PORT ở trên. Nếu chạy 2 service cùng máy, đổi 1 trong 2.
ORCHESTRATOR_STORY_AI_API_URL=
ORCHESTRATOR_STORY_AI_TIMEOUT_SEC=